{
    "version": 2,
    "framework": null,
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "routes": [
        {
            "src": "/(css|js|images|storage|assets|build)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "outputDirectory": "public",
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_KEY": "base64:SEO6abhlN0T8afteBjk8kuo/C9pFo3DXELVaMPc5LYw=",
        "APP_URL": "https://www.tubagusalwasii.my.id",
        "LOG_CHANNEL": "stderr",
        "DB_CONNECTION": "pgsql",
        "SESSION_DRIVER": "cookie",
        "CACHE_STORE": "array"
    }
}
