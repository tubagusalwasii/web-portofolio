{
    "version": 2,
    "framework": null,
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "routes": [
        {
            "src": "/(css|js|images|storage|assets|build)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "outputDirectory": "public",
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "LOG_CHANNEL": "stderr",
        "DB_CONNECTION": "pgsql",
        "VIEW_COMPILED_PATH": "/tmp",
        "SESSION_DRIVER": "cookie",
        "CACHE_STORE": "array",
        "CONFIG_CACHE": "/tmp/config.php",
        "ROUTES_CACHE": "/tmp/routes.php",
        "SERVICES_CACHE": "/tmp/services.php",
        "PACKAGES_CACHE": "/tmp/packages.php"
    }
}
